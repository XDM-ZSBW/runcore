# Core environment variables
# Copy to .env and fill in your values.

# --- Server ---
CORE_PORT=3577                   # Main server port (default: 3577)
CORE_SEARCH_PORT=3578            # Sidecar search port (default: 3578)
CORE_BRAIN_DIR=                  # Brain directory (default: ./brain)

# --- LLM Providers ---
OPENROUTER_API_KEY=
OLLAMA_URL=http://localhost:11434

# --- Email (Resend) ---
RESEND_API_KEY=
CORE_ALERT_EMAIL_FROM=           # e.g. agent@yourdomain.com
CORE_ALERT_EMAIL_TO=             # e.g. you@gmail.com

# --- Twilio (WhatsApp + Voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=          # WhatsApp-enabled sender, e.g. +14155238886

# --- Morning Briefing ---
BRIEFING_EMAIL_TO=               # comma-separated email recipients
BRIEFING_SMS_TO=                 # comma-separated phone numbers (Twilio)
BRIEFING_WHATSAPP_TO=            # comma-separated phone numbers (Twilio)
BRIEFING_HOUR=6                  # hour of day (0–23) to send briefing

# --- Agent Runtime ---
CORE_MAX_CONCURRENT_AGENTS=3
CORE_RUNTIME_TIMEOUT_MS=300000
CORE_EXTRACTION_MODEL=           # override model for background extraction

# --- Google Workspace ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- GitHub ---
GITHUB_WEBHOOK_SECRET=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Legacy: DASH_* prefixed env vars are still supported for backwards compatibility.
