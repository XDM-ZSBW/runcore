{
  "name": "library",
  "description": "Content library — SharePoint-inspired virtual folder navigation over the flat file registry. Folders are metadata-only; files stay in date-based storage.",
  "keywords": ["library", "files", "folders", "documents", "browse", "upload", "search", "recents", "favorites"],
  "files": [
    { "path": "folders.jsonl", "role": "data", "description": "Virtual folder hierarchy (append-only)" },
    { "path": "state.jsonl", "role": "data", "description": "Recents and favorites tracking (append-only)" }
  ],
  "endpoints": [
    { "path": "/api/library/tree", "method": "GET", "description": "Full folder tree with file counts" },
    { "path": "/api/library/folders/:id", "method": "GET", "description": "Folder contents (subfolders + files + breadcrumb)" },
    { "path": "/api/library/folders", "method": "POST", "description": "Create folder" },
    { "path": "/api/library/folders/:id", "method": "PATCH", "description": "Rename/move folder" },
    { "path": "/api/library/folders/:id", "method": "DELETE", "description": "Archive folder" },
    { "path": "/api/library/files", "method": "GET", "description": "List files with folder/category/search filters" },
    { "path": "/api/library/files/upload", "method": "POST", "description": "Upload file to library" },
    { "path": "/api/library/files/:id", "method": "GET", "description": "File metadata" },
    { "path": "/api/library/files/:id/download", "method": "GET", "description": "Download file content" },
    { "path": "/api/library/files/:id", "method": "PATCH", "description": "Update file metadata" },
    { "path": "/api/library/files/:id", "method": "DELETE", "description": "Archive file" },
    { "path": "/api/library/search", "method": "GET", "description": "Search files and folders" },
    { "path": "/api/library/recents", "method": "GET", "description": "Recent files/folders" },
    { "path": "/api/library/favorites", "method": "GET", "description": "Favorite items" },
    { "path": "/api/library/favorites/:id", "method": "POST", "description": "Toggle favorite" },
    { "path": "/api/library/stats", "method": "GET", "description": "Storage stats by folder/category" }
  ],
  "prompt": "## Content Library\nYou manage a virtual folder tree over the flat file registry. Folders are metadata-only — files live in date-based storage and link to folders via `meta.folderId`. Default root folders: Documents, Images, Media, Templates, Reports, Inbox. Use the library API to browse, upload, search, and organize files. When {name} asks about files, documents, or 'what do I have', query the library tree and search endpoints.",
  "promptOrder": 50
}
