{
  "name": "core-brain",
  "version": "0.1.0",
  "description": "File-based personal operating system for an AI agent — the brain: memory, context assembly, and decision cycle",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "tsx example/demo.ts",
    "chat": "tsx watch --env-file=.env src/server.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "agent",
    "context-engineering",
    "memory",
    "coala",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/ui": "^4.0.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.1.0",
    "@hono/node-server": "^1.19.9",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.30.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "hono": "^4.12.3",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.4.0"
  }
}
